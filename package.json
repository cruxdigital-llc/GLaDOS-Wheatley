{
  "name": "wheatley",
  "version": "0.1.0",
  "description": "A lightweight project board that uses GLaDOS-managed markdown files as its database",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.95.2",
    "fastify": "^5.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simple-git": "^3.33.0"
  }
}
